{
  "manifest_version": 3,
  "name": "Mind Stream",
  "version": "0.1.0",
  "description": "An extension for Mind Stream — Detects distraction, resets focus.",
  "minimum_chrome_version": "141",
  "action": {
    "default_title": "Mind Stream",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["sidePanel", "storage", "alarms", "notifications", "tabs"],
  "host_permissions": [
    "http://localhost/*",
    "http://localhost:*/*",
    "http://127.0.0.1/*",
    "http://127.0.0.1:*/*"
  ],
  "side_panel": {
    "default_path": "index.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png",
    "256": "icons/icon-256.png",
    "512": "icons/icon-512.png"
  }
}
